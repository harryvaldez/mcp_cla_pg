# PostgreSQL MCP Server environment template
# Copy to .env and update values for your environment.

# -----------------------------
# Core Database Connection
# -----------------------------
# Option A: full connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcp_test

# Option B: PG* vars (used only when DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=mcp_test

# -----------------------------
# Server Transport and Network
# -----------------------------
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_SERVER_NAME=PostgreSQL MCP Server

# -----------------------------
# Write Safety Controls (required)
# -----------------------------
# Must be explicitly set to true or false.
MCP_ALLOW_WRITE=false
MCP_CONFIRM_WRITE=false

# -----------------------------
# Runtime Limits and Pool
# -----------------------------
MCP_MAX_ROWS=500
MCP_POOL_MIN_SIZE=1
MCP_POOL_MAX_SIZE=20
MCP_POOL_TIMEOUT=60.0
MCP_POOL_MAX_WAITING=20
MCP_STATEMENT_TIMEOUT_MS=120000

# -----------------------------
# Rate Limit and Circuit Breaker
# -----------------------------
MCP_RATE_LIMIT_ENABLED=true
MCP_RATE_LIMIT_PER_MINUTE=600
MCP_BREAKER_TRIP_REJECTIONS=20
MCP_BREAKER_OPEN_SECONDS=30

# -----------------------------
# Least Privilege Table Scope
# -----------------------------
MCP_ENFORCE_TABLE_SCOPE=false
# Comma-separated list of schema.table entries.
# MCP_ALLOWED_TABLES=public.customers,public.orders
MCP_ALLOWED_TABLES=

# -----------------------------
# Audit Logging
# -----------------------------
MCP_AUDIT_LOG_FILE=mcp_audit.log
MCP_AUDIT_LOG_SQL_TEXT=false
MCP_AUDIT_REQUIRE_PROMPT=false
# If true, audit log write failures are fatal.
MCP_AUDIT_LOG_REQUIRED=false

# -----------------------------
# Logging
# -----------------------------
MCP_LOG_LEVEL=INFO
# MCP_LOG_FILE=./mcp-postgres.log
MCP_SKIP_CONFIRMATION=false

# -----------------------------
# TLS (HTTP transport)
# -----------------------------
# MCP_SSL_CERT=./certs/server.crt
# MCP_SSL_KEY=./certs/server.key

# -----------------------------
# Authentication
# -----------------------------
# Valid values: none, apikey, oidc, jwt, azure-ad, github, google, oauth2
FASTMCP_AUTH_TYPE=none

# API key mode
# FASTMCP_API_KEY=replace-with-strong-token

# OIDC mode
# FASTMCP_OIDC_CONFIG_URL=https://issuer/.well-known/openid-configuration
# FASTMCP_OIDC_CLIENT_ID=your-client-id
# FASTMCP_OIDC_CLIENT_SECRET=your-client-secret
# FASTMCP_OIDC_BASE_URL=https://your-mcp-host
# FASTMCP_OIDC_AUDIENCE=your-audience

# JWT mode
# FASTMCP_JWT_JWKS_URI=https://issuer/.well-known/jwks.json
# FASTMCP_JWT_ISSUER=https://issuer/
# FASTMCP_JWT_AUDIENCE=your-audience

# Azure AD mode
# FASTMCP_AZURE_AD_TENANT_ID=your-tenant-id
# FASTMCP_AZURE_AD_CLIENT_ID=your-client-id
# FASTMCP_AZURE_AD_CLIENT_SECRET=your-client-secret
# FASTMCP_AZURE_AD_BASE_URL=https://your-mcp-host
# FASTMCP_AZURE_AD_AUDIENCE=api://your-client-id

# GitHub mode
# FASTMCP_GITHUB_CLIENT_ID=your-client-id
# FASTMCP_GITHUB_CLIENT_SECRET=your-client-secret
# FASTMCP_GITHUB_BASE_URL=https://github.com

# Google mode
# FASTMCP_GOOGLE_CLIENT_ID=your-client-id
# FASTMCP_GOOGLE_CLIENT_SECRET=your-client-secret
# FASTMCP_GOOGLE_BASE_URL=https://your-mcp-host

# Generic OAuth2 mode
# FASTMCP_OAUTH_AUTHORIZE_URL=https://issuer/authorize
# FASTMCP_OAUTH_TOKEN_URL=https://issuer/token
# FASTMCP_OAUTH_CLIENT_ID=your-client-id
# FASTMCP_OAUTH_CLIENT_SECRET=your-client-secret
# FASTMCP_OAUTH_BASE_URL=https://your-mcp-host
# FASTMCP_OAUTH_JWKS_URI=https://issuer/.well-known/jwks.json
# FASTMCP_OAUTH_ISSUER=https://issuer/
# FASTMCP_OAUTH_AUDIENCE=your-audience

# -----------------------------
# FastMCP Features
# -----------------------------
# FASTMCP_TASKS_ENABLED=true
# MCP_TASKS_ENABLED=true

# Visibility filters (comma-separated; semicolon also supported)
# FASTMCP_INCLUDE_TAGS=public,readonly
# MCP_INCLUDE_TAGS=public,readonly
# FASTMCP_EXCLUDE_TAGS=experimental,internal
# MCP_EXCLUDE_TAGS=experimental,internal

# Metadata visibility toggle; currently ignored by FastMCP version in this repo.
# FASTMCP_INCLUDE_META=true
# MCP_INCLUDE_META=true

# Skills resources
MCP_SKILLS_RESOURCES_ENABLED=false
# MCP_SKILLS_DIRS=.trae/skills;C:/shared/skills
# FASTMCP_SKILLS_DIRS=.trae/skills

# -----------------------------
# OAuth Client Storage Backends
# -----------------------------
# Valid values: memory, disk, file, redis
# FASTMCP_CLIENT_STORAGE_BACKEND=memory
# FASTMCP_CLIENT_STORAGE_COLLECTION=fastmcp

# Disk/file backend
# FASTMCP_CLIENT_STORAGE_PATH=.fastmcp-client-storage
# FASTMCP_CLIENT_STORAGE_MAX_SIZE=104857600

# Redis backend (URL takes precedence if set)
# FASTMCP_CLIENT_STORAGE_REDIS_URL=redis://localhost:6379/0
# FASTMCP_CLIENT_STORAGE_REDIS_HOST=localhost
# FASTMCP_CLIENT_STORAGE_REDIS_PORT=6379
# FASTMCP_CLIENT_STORAGE_REDIS_DB=0
# FASTMCP_CLIENT_STORAGE_REDIS_PASSWORD=

# Optional Fernet key for client storage encryption (URL-safe base64 key)
# FASTMCP_CLIENT_STORAGE_ENCRYPTION_KEY=replace-with-valid-fernet-key

# -----------------------------
# SSH Tunnel to Database (optional)
# -----------------------------
# SSH_HOST=jump-host.example.com
# SSH_PORT=22
# SSH_USER=ssh-user
# SSH_PASSWORD=ssh-password
# SSH_PKEY=/path/to/private_key
# ALLOW_SSH_AGENT=false
